# ================================================================
# 环境变量模板 — 复制为 .env 并修改
#   cp .env.example .env
#
# 这是项目唯一的 .env 文件，用于 Docker Compose 容器运行。
# 身份验证通过前端 Konami 码（↑↑↓↓←→←→BABA）完成，无需额外密码。
# ================================================================

# MySQL 容器
MYSQL_ROOT_PASSWORD=请替换为随机密码
MYSQL_DATABASE=photodb

# 应用
DB_HOST=mysql
DB_USERNAME=root
DB_PASSWORD=${MYSQL_ROOT_PASSWORD}
JWT_SECRET=请替换为 openssl rand -base64 32 的输出
